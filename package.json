{
  "name": "adamant-schema",
  "version": "0.7.0",
  "description": "ADAMANT OpenAPI Specification",
  "scripts": {
    "bundle": "redocly bundle specification/openapi.yaml -o dist/schema.json --component-renaming-conflicts-severity=off",
    "start": "npm run bundle && ts-node app.ts",
    "start:watch": "nodemon",
    "prepare": "husky"
  },
  "author": "bludnic",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/swagger-ui-express": "^4.1.8",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "openapi-typescript-codegen": "^0.30.0",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@redocly/cli": "^2.34.0",
    "express": "^4.22.2",
    "swagger-ui-express": "^4.6.3"
  },
  "lint-staged": {
    "*.{json,yaml,js,ts}": [
      "prettier --write"
    ]
  }
}
